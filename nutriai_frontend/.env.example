# ============================================
# NutriAI Frontend — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- App ----------
EXPO_PUBLIC_APP_NAME=NutriAI
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENVIRONMENT=development

# ---------- API ----------
# localhost works for simulator, emulator, and web
# Real device on Wi-Fi:   http://YOUR_LAN_IP:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_API_TIMEOUT=10000

# ---------- Auth ----------
EXPO_PUBLIC_AUTH_ENABLED=true
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
EXPO_PUBLIC_APPLE_CLIENT_ID=your-apple-client-id

# Dev API key (must match DEV_API_KEY in backend docker-compose.yml)
EXPO_PUBLIC_DEV_API_KEY=dev-token-key-2026

# ---------- Analytics ----------
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id

# ---------- Feature Flags ----------
EXPO_PUBLIC_FEATURE_SCANNER=true
EXPO_PUBLIC_FEATURE_AI_RECIPES=true
EXPO_PUBLIC_FEATURE_PREMIUM=false

# ---------- External Services ----------
EXPO_PUBLIC_NUTRITION_API_KEY=your-nutrition-api-key
EXPO_PUBLIC_FOOD_DATABASE_URL=https://foodapi.example.com

# ---------- Debug ----------
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_CONSOLE_LOGS=true

# ---------- Storage ----------
EXPO_PUBLIC_CACHE_ENABLED=true
EXPO_PUBLIC_STORAGE_PREFIX=nutriai_

# ---------- Notifications ----------
EXPO_PUBLIC_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_NOTIFICATION_CHANNEL=nutriai-notifications